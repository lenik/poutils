#: src/poedit.c:205
msgid "Purpose:"
msgstr "Objectif :"

#: src/poedit.c:206
msgid "  Efficiently apply many already-translated l10n messages into PO files."
msgstr "  Appliquer efficacement de nombreux messages l10n deja traduits dans des fichiers PO."

#: src/poedit.c:207
msgid "  This tool is mainly designed for AI-assisted coding workflows."
msgstr "  Cet outil est principalement concu pour des workflows de developpement assistes par IA."

#: src/poedit.c:209
msgid "AI usage requirements:"
msgstr "Exigences d'utilisation de l'IA :"

#: src/poedit.c:210
msgid "  1) Translate multiple messages in advance (manually) before running poedit."
msgstr "  1) Traduire manuellement plusieurs messages a l'avance avant d'executer poedit."

#: src/poedit.c:211
msgid "  2) Use poedit for batch update to avoid one-by-one tool calls."
msgstr "  2) Utiliser poedit pour une mise a jour en lot afin d'eviter des appels outil un par un."

#: src/poedit.c:212
msgid "  3) Do NOT use poedit to generate placeholders or copy msgid to msgstr."
msgstr "  3) Ne PAS utiliser poedit pour generer des placeholders ni copier msgid vers msgstr."

#: src/poedit.c:213
msgid "     Doing so defeats the purpose of this tool."
msgstr "     Cela annule l'objectif de cet outil."

#: src/poedit.c:217
msgid "Usage: poedit [OPTIONS]"
msgstr "Utilisation : poedit [OPTIONS]"

#: src/poedit.c:220
msgid "Options:"
msgstr "Options :"

#: src/poedit.c:222
msgid "mapping file or directory (optional: default stdin)"
msgstr "fichier ou repertoire de mapping (optionnel, stdin par defaut)"

#: src/poedit.c:224
msgid "language code for single mapping file"
msgstr "code langue pour un fichier de mapping unique"

#: src/poedit.c:226
msgid "PO directory (default: po)"
msgstr "repertoire PO (defaut : po)"

#: src/poedit.c:228
msgid "show plan but do not modify files"
msgstr "afficher le plan sans modifier les fichiers"

#: src/poedit.c:230
msgid "repeat for more verbose loggings"
msgstr "repeter pour des logs plus verbeux"

#: src/poedit.c:232
msgid "show less logging messages"
msgstr "afficher moins de messages de log"

#: src/poedit.c:234
msgid "show this help and exit"
msgstr "afficher cette aide et quitter"

#: src/poedit.c:236
msgid "show version and exit"
msgstr "afficher la version et quitter"

#: src/poedit.c:282
#, c-format
msgid "error: input not found: %s\n"
msgstr "erreur : entree introuvable : %s\n"

#: src/poedit.c:288
#, c-format
msgid "error: failed to read mapping file: %s\n"
msgstr "erreur : echec de lecture du fichier de mapping : %s\n"

#: src/poedit.c:301
#, c-format
msgid "error: unsupported input type: %s\n"
msgstr "erreur : type d'entree non pris en charge : %s\n"

#: src/poedit.c:307
#, c-format
msgid "error: failed to open input directory: %s\n"
msgstr "erreur : impossible d'ouvrir le repertoire d'entree : %s\n"

#: src/poedit.c:368
msgid "error: input contains only msgid<TAB>msgstr entries; explicit language is required."
msgstr "erreur : l'entree contient uniquement des couples msgid<TAB>msgstr ; une langue explicite est requise."

#: src/poedit.c:369
msgid "Please use [lang<TAB>]msgid<TAB>msgstr format."
msgstr "Veuillez utiliser le format [lang<TAB>]msgid<TAB>msgstr."

#: src/poedit.c:378
#, c-format
msgid "error: invalid field count in %s:%d\n"
msgstr "erreur : nombre de champs invalide dans %s:%d\n"

#: src/poedit.c:385
#, c-format
msgid "error: no language resolved for %s:%d\n"
msgstr "erreur : aucune langue resolue pour %s:%d\n"

#: src/poedit.c:416
#, c-format
msgid "[dry-run] %s: %s (updated=%d, fuzzy_removed=%d)\n"
msgstr "[dry-run] %s : %s (mis a jour=%d, fuzzy_supprimes=%d)\n"

#: src/poedit.c:416
msgid "would update"
msgstr "serait mis a jour"

#: src/poedit.c:416 src/poedit.c:419
msgid "no changes"
msgstr "aucun changement"

#: src/poedit.c:419
#, c-format
msgid "%s: %s (updated=%d, fuzzy_removed=%d)\n"
msgstr "%s : %s (mis a jour=%d, fuzzy_supprimes=%d)\n"

#: src/poedit.c:419
msgid "updated"
msgstr "mis a jour"

#: src/poedit.c:441
#, c-format
msgid "warn: skip missing PO file: %s\n"
msgstr "avertissement : fichier PO manquant ignore : %s\n"

#: src/poedit.c:453
#, c-format
msgid "error: cannot infer language from target file: %s\n"
msgstr "erreur : impossible de deduire la langue du fichier cible : %s\n"

#: src/poedit.c:459
#, c-format
msgid "warn: no mapping found for language %s; skip %s\n"
msgstr "avertissement : aucun mapping pour la langue %s ; %s ignore\n"

#: src/poedit.c:499
msgid "error: no mapping entries loaded"
msgstr "erreur : aucune entree de mapping chargee"
