#: src/poedit.c:204
msgid "Purpose:"
msgstr "目的:"

#: src/poedit.c:205
msgid "  Efficiently apply many already-translated l10n messages into PO files."
msgstr "  既に翻訳済みの l10n メッセージを PO ファイルへ効率的に一括反映します。"

#: src/poedit.c:206
msgid "  poedit is usually used to supplement translations by providing only newly added entries."
msgstr "  poedit は通常、新たに追加されたエントリだけを与えることで翻訳を補うために使われます。"

#: src/poedit.c:208
msgid "  This tool is mainly designed for AI-assisted coding workflows."
msgstr "  このツールは主に AI 支援コーディングワークフロー向けに設計されています。"

#: src/poedit.c:210
msgid "AI usage requirements:"
msgstr "AI 利用要件:"

#: src/poedit.c:212
msgid "  1) Translate multiple messages in advance (manually) before running poedit."
msgstr "  1) poedit 実行前に複数メッセージを事前に手動翻訳してください。"

#: src/poedit.c:213
msgid "  2) Use poedit for batch update to avoid one-by-one tool calls."
msgstr "  2) 1 件ずつのツール呼び出しを避けるため、poedit で一括更新してください。"

#: src/poedit.c:214
msgid "  3) Do NOT use poedit to generate placeholders or copy msgid to msgstr."
msgstr "  3) プレースホルダー生成や msgid の msgstr へのコピーに poedit を使わないでください。"

#: src/poedit.c:215
msgid "     Doing so defeats the purpose of this tool."
msgstr "     それはこのツールの目的を損ないます。"

#: src/poedit.c:216
msgid "  4) AI must first identify missing entries in current translations, "
msgstr "  4) AI はまず現在の翻訳で不足している項目を特定し、"

#: src/poedit.c:217
msgid "     translate them manually."
msgstr "     それらを手動で翻訳し、"

#: src/poedit.c:218
msgid "     then apply to PO files with this tool in one batch."
msgstr "     その後このツールで PO ファイルに一括適用すること。"

#: src/poedit.c:222
msgid "Usage: poedit [OPTIONS]"
msgstr "使い方: poedit [OPTIONS]"

#: src/poedit.c:225
msgid "Input format: (lang can be inferred from filename or subdir)"
msgstr "入力形式:（言語はファイル名またはサブディレクトリから推定できます）"

#: src/poedit.c:226
msgid "  lang<TAB>msgid<TAB>msgstr"
msgstr "  lang<TAB>msgid<TAB>msgstr"

#: src/poedit.c:227
msgid "-or-"
msgstr "-または-"

#: src/poedit.c:228
msgid "  msgid<TAB>msgstr"
msgstr "  msgid<TAB>msgstr"

#: src/poedit.c:230
msgid "  lang conflict resolution: [lang<TAB>] > [filename] > [subdir]"
msgstr "  言語競合の解決順: [lang<TAB>] > [filename] > [subdir]"

#: src/poedit.c:232
msgid "Options:"
msgstr "オプション:"

#: src/poedit.c:234
msgid "mapping file or directory (optional: default stdin)"
msgstr "マッピングファイルまたはディレクトリ（任意、既定は stdin）"

#: src/poedit.c:236
msgid "language code for single mapping file"
msgstr "単一マッピングファイル用の言語コード"

#: src/poedit.c:238
msgid "PO directory (default: po)"
msgstr "PO ディレクトリ（既定: po）"

#: src/poedit.c:240
msgid "show plan but do not modify files"
msgstr "計画のみ表示し、ファイルは変更しない"

#: src/poedit.c:242
msgid "repeat for more verbose loggings"
msgstr "指定を繰り返すと詳細ログを表示"

#: src/poedit.c:244
msgid "show less logging messages"
msgstr "ログメッセージを少なく表示"

#: src/poedit.c:246
msgid "show this help and exit"
msgstr "このヘルプを表示して終了"

#: src/poedit.c:248
msgid "show version and exit"
msgstr "バージョンを表示して終了"

#: src/poedit.c:317
#, c-format
msgid "error: input not found: %s\n"
msgstr "エラー: 入力が見つかりません: %s\n"

#: src/poedit.c:323
#, c-format
msgid "error: failed to read mapping file: %s\n"
msgstr "エラー: マッピングファイルの読み込みに失敗しました: %s\n"

#: src/poedit.c:337
#, c-format
msgid "error: unsupported input type: %s\n"
msgstr "エラー: サポートされていない入力タイプです: %s\n"

#: src/poedit.c:343
#, c-format
msgid "error: failed to open input directory: %s\n"
msgstr "エラー: 入力ディレクトリを開けませんでした: %s\n"

#: src/poedit.c:405
msgid "error: input contains only msgid<TAB>msgstr entries; explicit language is required."
msgstr "エラー: 入力が msgid<TAB>msgstr のみです。明示的な言語指定が必要です。"

#: src/poedit.c:407
msgid "Please use [lang<TAB>]msgid<TAB>msgstr format."
msgstr "[lang<TAB>]msgid<TAB>msgstr 形式を使用してください。"

#: src/poedit.c:416
#, c-format
msgid "error: invalid field count in %s:%d\n"
msgstr "エラー: %s:%d のフィールド数が不正です\n"

#: src/poedit.c:425
#, c-format
msgid "error: no language resolved for %s:%d\n"
msgstr "エラー: %s:%d の言語を解決できません\n"

#: src/poedit.c:458
#, c-format
msgid "[dry-run] %s: %s (updated=%d, fuzzy_removed=%d)\n"
msgstr "[dry-run] %s: %s (更新=%d, fuzzy削除=%d)\n"

#: src/poedit.c:459
msgid "would update"
msgstr "更新予定"

#: src/poedit.c:459 src/poedit.c:462
msgid "no changes"
msgstr "変更なし"

#: src/poedit.c:461
#, c-format
msgid "%s: %s (updated=%d, fuzzy_removed=%d)\n"
msgstr "%s: %s (更新=%d, fuzzy削除=%d)\n"

#: src/poedit.c:462
msgid "updated"
msgstr "更新済み"

#: src/poedit.c:483
#, c-format
msgid "warn: skip missing PO file: %s\n"
msgstr "警告: 存在しない PO ファイルをスキップします: %s\n"

#: src/poedit.c:496
#, c-format
msgid "error: cannot infer language from target file: %s\n"
msgstr "エラー: 対象ファイルから言語を推測できません: %s\n"

#: src/poedit.c:502
#, c-format
msgid "warn: no mapping found for language %s; skip %s\n"
msgstr "警告: 言語 %s のマッピングがありません。%s をスキップします\n"

#: src/poedit.c:542
msgid "error: no mapping entries loaded"
msgstr "エラー: マッピングエントリが読み込まれていません"
