#: src/poedit.c:205
msgid "Purpose:"
msgstr "用途："

#: src/poedit.c:206
msgid "  Efficiently apply many already-translated l10n messages into PO files."
msgstr "  有效率地將大量已翻譯的在地化訊息批次套用到 PO 檔案。"

#: src/poedit.c:207
msgid "  This tool is mainly designed for AI-assisted coding workflows."
msgstr "  此工具主要為 AI 輔助開發工作流程而設計。"

#: src/poedit.c:209
msgid "AI usage requirements:"
msgstr "AI 使用要求："

#: src/poedit.c:210
msgid "  1) Translate multiple messages in advance (manually) before running poedit."
msgstr "  1) 執行 poedit 前，請先手動完成多條訊息翻譯。"

#: src/poedit.c:211
msgid "  2) Use poedit for batch update to avoid one-by-one tool calls."
msgstr "  2) 使用 poedit 進行批次更新，避免逐條呼叫工具。"

#: src/poedit.c:212
msgid "  3) Do NOT use poedit to generate placeholders or copy msgid to msgstr."
msgstr "  3) 不要用 poedit 產生佔位翻譯或將 msgid 直接複製到 msgstr。"

#: src/poedit.c:213
msgid "     Doing so defeats the purpose of this tool."
msgstr "     否則會失去本工具的設計意義。"

#: src/poedit.c:217
msgid "Usage: poedit [OPTIONS]"
msgstr "用法：poedit [選項]"

#: src/poedit.c:220
msgid "Options:"
msgstr "選項："

#: src/poedit.c:222
msgid "mapping file or directory (optional: default stdin)"
msgstr "映射檔或目錄（可選，預設 stdin）"

#: src/poedit.c:224
msgid "language code for single mapping file"
msgstr "單一映射檔的語言代碼"

#: src/poedit.c:226
msgid "PO directory (default: po)"
msgstr "PO 目錄（預設：po）"

#: src/poedit.c:228
msgid "show plan but do not modify files"
msgstr "僅顯示計畫，不修改檔案"

#: src/poedit.c:230
msgid "repeat for more verbose loggings"
msgstr "重複指定可顯示更詳細日誌"

#: src/poedit.c:232
msgid "show less logging messages"
msgstr "顯示較少日誌訊息"

#: src/poedit.c:234
msgid "show this help and exit"
msgstr "顯示說明並離開"

#: src/poedit.c:236
msgid "show version and exit"
msgstr "顯示版本並離開"

#: src/poedit.c:282
#, c-format
msgid "error: input not found: %s\n"
msgstr "錯誤：找不到輸入：%s\n"

#: src/poedit.c:288
#, c-format
msgid "error: failed to read mapping file: %s\n"
msgstr "錯誤：讀取映射檔失敗：%s\n"

#: src/poedit.c:301
#, c-format
msgid "error: unsupported input type: %s\n"
msgstr "錯誤：不支援的輸入類型：%s\n"

#: src/poedit.c:307
#, c-format
msgid "error: failed to open input directory: %s\n"
msgstr "錯誤：無法開啟輸入目錄：%s\n"

#: src/poedit.c:368
msgid "error: input contains only msgid<TAB>msgstr entries; explicit language is required."
msgstr "錯誤：輸入僅包含 msgid<TAB>msgstr 條目；必須明確指定語言。"

#: src/poedit.c:369
msgid "Please use [lang<TAB>]msgid<TAB>msgstr format."
msgstr "請使用 [lang<TAB>]msgid<TAB>msgstr 格式。"

#: src/poedit.c:378
#, c-format
msgid "error: invalid field count in %s:%d\n"
msgstr "錯誤：%s:%d 欄位數量無效\n"

#: src/poedit.c:385
#, c-format
msgid "error: no language resolved for %s:%d\n"
msgstr "錯誤：無法為 %s:%d 解析語言\n"

#: src/poedit.c:416
#, c-format
msgid "[dry-run] %s: %s (updated=%d, fuzzy_removed=%d)\n"
msgstr "[dry-run] %s: %s (已更新=%d, 已移除模糊=%d)\n"

#: src/poedit.c:416
msgid "would update"
msgstr "將會更新"

#: src/poedit.c:416 src/poedit.c:419
msgid "no changes"
msgstr "沒有變更"

#: src/poedit.c:419
#, c-format
msgid "%s: %s (updated=%d, fuzzy_removed=%d)\n"
msgstr "%s: %s (已更新=%d, 已移除模糊=%d)\n"

#: src/poedit.c:419
msgid "updated"
msgstr "已更新"

#: src/poedit.c:441
#, c-format
msgid "warn: skip missing PO file: %s\n"
msgstr "警告：略過缺失的 PO 檔：%s\n"

#: src/poedit.c:453
#, c-format
msgid "error: cannot infer language from target file: %s\n"
msgstr "錯誤：無法從目標檔推斷語言：%s\n"

#: src/poedit.c:459
#, c-format
msgid "warn: no mapping found for language %s; skip %s\n"
msgstr "警告：找不到語言 %s 的映射；略過 %s\n"

#: src/poedit.c:499
msgid "error: no mapping entries loaded"
msgstr "錯誤：未載入任何映射條目"
