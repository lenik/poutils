#: src/poedit.c:204
msgid "Purpose:"
msgstr "목적:"

#: src/poedit.c:205
msgid "  Efficiently apply many already-translated l10n messages into PO files."
msgstr "  이미 번역된 l10n 메시지를 PO 파일에 효율적으로 일괄 반영합니다."

#: src/poedit.c:206
msgid "  poedit is usually used to supplement translations by providing only newly added entries."
msgstr "  poedit는 보통 새로 추가된 항목만 제공하여 번역을 보완하는 데 쓰입니다."

#: src/poedit.c:208
msgid "  This tool is mainly designed for AI-assisted coding workflows."
msgstr "  이 도구는 주로 AI 보조 코딩 워크플로를 위해 설계되었습니다."

#: src/poedit.c:210
msgid "AI usage requirements:"
msgstr "AI 사용 요구사항:"

#: src/poedit.c:212
msgid "  1) Translate multiple messages in advance (manually) before running poedit."
msgstr "  1) poedit 실행 전에 여러 메시지를 미리 수동 번역하세요."

#: src/poedit.c:213
msgid "  2) Use poedit for batch update to avoid one-by-one tool calls."
msgstr "  2) 도구를 하나씩 호출하지 않도록 poedit으로 일괄 업데이트하세요."

#: src/poedit.c:214
msgid "  3) Do NOT use poedit to generate placeholders or copy msgid to msgstr."
msgstr "  3) 자리표시자 생성이나 msgid를 msgstr로 복사하는 데 poedit을 사용하지 마세요."

#: src/poedit.c:215
msgid "     Doing so defeats the purpose of this tool."
msgstr "     그렇게 하면 이 도구의 목적이 사라집니다."

#: src/poedit.c:216
msgid "  4) AI must first identify missing entries in current translations, "
msgstr "  4) AI는 먼저 현재 번역에서 누락된 항목을 찾아내고,"

#: src/poedit.c:217
msgid "     translate them manually."
msgstr "     이를 수동으로 번역한 뒤,"

#: src/poedit.c:218
msgid "     then apply to PO files with this tool in one batch."
msgstr "     이 도구로 PO 파일에 한 번에 일괄 적용해야 합니다."

#: src/poedit.c:222
msgid "Usage: poedit [OPTIONS]"
msgstr "사용법: poedit [옵션]"

#: src/poedit.c:225
msgid "Input format: (lang can be inferred from filename or subdir)"
msgstr "입력 형식: (언어는 파일명 또는 하위 디렉터리에서 유추할 수 있음)"

#: src/poedit.c:226
msgid "  lang<TAB>msgid<TAB>msgstr"
msgstr "  lang<TAB>msgid<TAB>msgstr"

#: src/poedit.c:227
msgid "-or-"
msgstr "-또는-"

#: src/poedit.c:228
msgid "  msgid<TAB>msgstr"
msgstr "  msgid<TAB>msgstr"

#: src/poedit.c:230
msgid "  lang conflict resolution: [lang<TAB>] > [filename] > [subdir]"
msgstr "  언어 충돌 해결 순서: [lang<TAB>] > [filename] > [subdir]"

#: src/poedit.c:232
msgid "Options:"
msgstr "옵션:"

#: src/poedit.c:234
msgid "mapping file or directory (optional: default stdin)"
msgstr "매핑 파일 또는 디렉터리(선택 사항, 기본값 stdin)"

#: src/poedit.c:236
msgid "language code for single mapping file"
msgstr "단일 매핑 파일용 언어 코드"

#: src/poedit.c:238
msgid "PO directory (default: po)"
msgstr "PO 디렉터리(기본값: po)"

#: src/poedit.c:240
msgid "show plan but do not modify files"
msgstr "계획만 표시하고 파일은 수정하지 않음"

#: src/poedit.c:242
msgid "repeat for more verbose loggings"
msgstr "더 자세한 로그를 위해 반복 지정"

#: src/poedit.c:244
msgid "show less logging messages"
msgstr "로그 메시지 축소 표시"

#: src/poedit.c:246
msgid "show this help and exit"
msgstr "도움말 표시 후 종료"

#: src/poedit.c:248
msgid "show version and exit"
msgstr "버전 표시 후 종료"

#: src/poedit.c:317
#, c-format
msgid "error: input not found: %s\n"
msgstr "오류: 입력을 찾을 수 없음: %s\n"

#: src/poedit.c:323
#, c-format
msgid "error: failed to read mapping file: %s\n"
msgstr "오류: 매핑 파일 읽기 실패: %s\n"

#: src/poedit.c:337
#, c-format
msgid "error: unsupported input type: %s\n"
msgstr "오류: 지원되지 않는 입력 유형: %s\n"

#: src/poedit.c:343
#, c-format
msgid "error: failed to open input directory: %s\n"
msgstr "오류: 입력 디렉터리를 열 수 없음: %s\n"

#: src/poedit.c:405
msgid "error: input contains only msgid<TAB>msgstr entries; explicit language is required."
msgstr "오류: 입력에 msgid<TAB>msgstr 항목만 있습니다. 명시적 언어 지정이 필요합니다."

#: src/poedit.c:407
msgid "Please use [lang<TAB>]msgid<TAB>msgstr format."
msgstr "[lang<TAB>]msgid<TAB>msgstr 형식을 사용하세요."

#: src/poedit.c:416
#, c-format
msgid "error: invalid field count in %s:%d\n"
msgstr "오류: %s:%d의 필드 개수가 잘못되었습니다\n"

#: src/poedit.c:425
#, c-format
msgid "error: no language resolved for %s:%d\n"
msgstr "오류: %s:%d의 언어를 확인할 수 없습니다\n"

#: src/poedit.c:458
#, c-format
msgid "[dry-run] %s: %s (updated=%d, fuzzy_removed=%d)\n"
msgstr "[dry-run] %s: %s (업데이트=%d, fuzzy제거=%d)\n"

#: src/poedit.c:459
msgid "would update"
msgstr "업데이트 예정"

#: src/poedit.c:459 src/poedit.c:462
msgid "no changes"
msgstr "변경 없음"

#: src/poedit.c:461
#, c-format
msgid "%s: %s (updated=%d, fuzzy_removed=%d)\n"
msgstr "%s: %s (업데이트=%d, fuzzy제거=%d)\n"

#: src/poedit.c:462
msgid "updated"
msgstr "업데이트됨"

#: src/poedit.c:483
#, c-format
msgid "warn: skip missing PO file: %s\n"
msgstr "경고: 누락된 PO 파일 건너뜀: %s\n"

#: src/poedit.c:496
#, c-format
msgid "error: cannot infer language from target file: %s\n"
msgstr "오류: 대상 파일에서 언어를 추론할 수 없음: %s\n"

#: src/poedit.c:502
#, c-format
msgid "warn: no mapping found for language %s; skip %s\n"
msgstr "경고: 언어 %s의 매핑이 없어 %s 건너뜀\n"

#: src/poedit.c:542
msgid "error: no mapping entries loaded"
msgstr "오류: 매핑 항목이 로드되지 않았습니다"
